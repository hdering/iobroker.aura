{
  "common": {
    "name": "aura",
    "version": "0.1.5",
    "title": "Aura Visualisierung",
    "titleLang": {
      "en": "Aura Visualisation",
      "de": "Aura Visualisierung"
    },
    "desc": {
      "en": "Modern visualization dashboard for ioBroker",
      "de": "Modernes Visualisierungs-Dashboard für ioBroker"
    },
    "type": "visualization",
    "license": "MIT",
    "mode": "daemon",
    "allowInit": true,
    "webExtension": "www/",
    "noIntro": true,
    "singleton": true,
    "adminUI": { "config": "none" },
    "localLink": "",
    "localLinks": {
      "🖥️ Frontend (Dashboard)": "%protocol%://%ip%:8082/aura/",
      "⚙️ Backend (Admin)": "%protocol%://%ip%:8082/aura/#/admin"
    },
    "authors": ["Aura"],
    "keywords": ["visualization", "dashboard"]
  },
  "native": {},
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "If adapter connected to ioBroker",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
