{
  "name": "iobroker.aura",
  "version": "0.5.30",
  "description": "Modern visualization dashboard for ioBroker",
  "author": "Hermann Dering <aura@dering-online.de>",
  "main": "main.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "admin/",
    "lib/",
    "main.js",
    "www/",
    "src-vis/i18n/",
    "io-package.json"
  ],
  "keywords": [
    "ioBroker",
    "visualization",
    "dashboard",
    "tablet",
    "ical",
    "calendar",
    "evcc",
    "gauge",
    "chart",
    "tiles"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdering/ioBroker.aura.git"
  },
  "bugs": {
    "url": "https://github.com/hdering/ioBroker.aura/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:adapter": "tsc && cross-env VITE_BASE=/aura/ vite build",
    "preview": "vite preview",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint src-vis main.js",
    "test": "node test/adapter.test.js",
    "test:package": "node test/adapter.test.js",
    "test:integration": "node test/adapter.test.js",
    "release": "release-script",
    "translate": "translate-adapter"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/react": "^6.0.2",
    "@iobroker/adapter-core": "^3.3.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "ical.js": "^2.2.1",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.4.4",
    "react-resizable": "^3.1.3",
    "react-router-dom": "^7.14.0",
    "recharts": "^2.12.7",
    "socket.io-client": "^2.5.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/socket.io-client": "^1.4.36",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.3"
  }
}
