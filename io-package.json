{
  "common": {
    "name": "aura",
    "version": "0.3.73",
    "titleLang": {
      "en": "Aura",
      "de": "Aura",
      "ru": "Aura",
      "pt": "Aura",
      "nl": "Aura",
      "fr": "Aura",
      "it": "Aura",
      "es": "Aura",
      "pl": "Aura",
      "uk": "Aura",
      "zh-cn": "Aura"
    },
    "desc": {
      "en": "Modern visualization dashboard for ioBroker",
      "de": "Modernes Visualisierungs-Dashboard für ioBroker",
      "ru": "Современная панель визуализации для ioBroker",
      "pt": "Painel de visualização moderno para ioBroker",
      "nl": "Modern visualisatiedashboard voor ioBroker",
      "fr": "Tableau de bord de visualisation moderne pour ioBroker",
      "it": "Dashboard di visualizzazione moderna per ioBroker",
      "es": "Panel de visualización moderno para ioBroker",
      "pl": "Nowoczesny panel wizualizacji dla ioBroker",
      "uk": "Сучасна панель візуалізації для ioBroker",
      "zh-cn": "ioBroker 的现代可视化仪表板"
    },
    "authors": [
      "Hermann Dering <aura@dering-online.de>"
    ],
    "keywords": [
      "visualization",
      "dashboard",
      "vis",
      "tablet",
      "ical",
      "calendar",
      "evcc",
      "gauge",
      "chart"
    ],
    "icon": "admin/aura.svg",
    "extIcon": "https://raw.githubusercontent.com/hdering/ioBroker.aura/main/admin/aura.svg",
    "type": "visualization",
    "license": "MIT",
    "licenseInformation": {
      "license": "MIT",
      "type": "free"
    },
    "mode": "daemon",
    "allowInit": true,
    "compact": false,
    "tier": 3,
    "connectionType": "local",
    "dataSource": "push",
    "webExtension": "www/",
    "noIntro": true,
    "singleton": true,
    "adminUI": { "config": "none" },
    "localLinks": {
      "Dashboard": "%protocol%://%ip%:8082/aura/",
      "Admin": "%protocol%://%ip%:8082/aura/#/admin"
    },
    "dependencies": [
      { "iobroker.admin": ">=6.0.0" }
    ],
    "globalDependencies": [
      { "js-controller": ">=5.0.19" }
    ],
    "news": {
      "0.3.73": {
        "en": "Stable fingerprint-based client ID – no more duplicate devices on mobile",
        "de": "Stabile fingerprint-basierte Client-ID – kein Duplizieren von Geräten auf Mobilgeräten"
      },
      "0.3.72": {
        "en": "Calendar widget: fetch via state relay instead of sendTo for reliable operation",
        "de": "Kalender-Widget: Fetch via State-Relay statt sendTo für zuverlässigen Betrieb"
      },
      "0.3.69": {
        "en": "Calendar fetch timeout, transparent widget border in edit mode, solid fill colors",
        "de": "Kalender-Fetch Timeout, gestrichelter Rahmen für transparente Widgets im Editiermodus"
      },
      "0.3.64": {
        "en": "New widget: waste collection with configurable bins and icons",
        "de": "Neues Widget: Müllabfuhr mit konfigurierbaren Tonnen und Icons"
      },
      "0.3.63": {
        "en": "New widget: fill level indicator (tank, water, gas) – vertical and horizontal",
        "de": "Neues Widget: Füllstandsanzeige (Tank, Wasser, Gas) – vertikal und horizontal"
      },
      "0.3.38": {
        "en": "Add Catppuccin themes (Latte, Frappé, Macchiato, Mocha)",
        "de": "Catppuccin Themes hinzugefügt (Latte, Frappé, Macchiato, Mocha)"
      },
      "0.1.0": {
        "en": "Initial release",
        "de": "Erstveröffentlichung"
      }
    }
  },
  "native": {},
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "If adapter connected to ioBroker",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "config.dashboard",
      "type": "state",
      "common": {
        "name": "Dashboard configuration",
        "type": "string",
        "role": "json",
        "read": true,
        "write": true,
        "def": "{\"widgets\":[]}"
      },
      "native": {}
    },
    {
      "_id": "navigate.url",
      "type": "state",
      "common": {
        "name": "Navigate to URL or tab slug",
        "type": "string",
        "role": "url",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "calendar.request",
      "type": "state",
      "common": {
        "name": "Calendar fetch request (JSON: {id, url})",
        "type": "string",
        "role": "json",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "calendar.response",
      "type": "state",
      "common": {
        "name": "Calendar fetch response (JSON: {id, content|error})",
        "type": "string",
        "role": "json",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    }
  ]
}
